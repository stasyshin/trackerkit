# Fallback values for local example runs.
# Real local credentials should be placed in `.env`.

JIRA_BASE_URL=https://your-jira.example.com/
JIRA_TOKEN=your-jira-token
# Optional Jira relation mapping.
# Format: Type name;Another type
# Strict format is also supported: Type name|outward label|inward label
JIRA_RELATES_LINK_TYPES=Relates
JIRA_BLOCKS_LINK_TYPES=Blocks
# For full contains CRUD, create a custom Jira link type and map it here.
# If set without JIRA_CONTAINS_MODE, the library uses custom_link_mapping for contains.
JIRA_CONTAINS_LINK_TYPES=
YANDEX_TOKEN=your-yandex-token
YANDEX_CLOUD_ORG_ID=your-yandex-cloud-org-id
YANDEX_ORG_ID=your-yandex-org-id
ASANA_TOKEN=your-asana-token
ASANA_PROJECT_ID=your-asana-project-id
